generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Admin {
  id        String    @id @default(uuid()) @db.Uuid
  email     String    @unique
  password  String
  name      String
  createdAt DateTime  @default(now())
  articles  Article[]
}

model Doctor {
  id            String     @id @default(uuid()) @db.Uuid
  email         String     @unique
  password      String
  name          String
  specialty     String
  languages     String[]
  phone         String
  isAvailable   Boolean    @default(true)
  rating        Float      @default(0)
  totalSessions Int        @default(0)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  bookings      Booking[]
  feedback      Feedback[]
  services      Service[]
}

model Service {
  id              String    @id @default(uuid()) @db.Uuid
  name            String
  description     String
  durationMinutes Int
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  bookings        Booking[]
  doctors         Doctor[]
}

model Booking {
  id             String        @id
  serviceId      String        @db.Uuid
  service        Service       @relation(fields: [serviceId], references: [id])
  doctorId       String        @db.Uuid
  doctor         Doctor        @relation(fields: [doctorId], references: [id])
  clientPhone    String
  clientAge      Int
  clientSex      String
  clientLanguage String
  clientAddress  String
  clientDetail   String?
  date           DateTime      @db.Date
  timeSlot       String
  status         BookingStatus @default(PENDING)
  createdAt      DateTime      @default(now())
  feedback       Feedback?
}

enum BookingStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
}

model Article {
  id        String   @id @default(uuid()) @db.Uuid
  title     String
  content   String
  category  String
  adminId   String   @db.Uuid
  admin     Admin    @relation(fields: [adminId], references: [id])
  views     Int      @default(0)
  createdAt DateTime @default(now())
}

model ChatLog {
  id           String   @id @default(uuid()) @db.Uuid
  sessionToken String
  message      String
  response     String
  createdAt    DateTime @default(now())

  @@index([sessionToken])
}

model Feedback {
  id        String   @id @default(uuid()) @db.Uuid
  doctorId  String   @db.Uuid
  doctor    Doctor   @relation(fields: [doctorId], references: [id])
  bookingId String?  @unique
  booking   Booking? @relation(fields: [bookingId], references: [id])
  rating    Int
  comment   String?
  createdAt DateTime @default(now())
}
