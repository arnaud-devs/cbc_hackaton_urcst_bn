model Clinic {
  id               String   @id @default(uuid()) @db.Uuid
  name             String
  schedule         Json     // {"monday": {"open": "08:00", "close": "18:00"}, "sunday": null}
  address          String
  phone            String
  description      String   @db.Text
  services         Json[]   // [{"name": "Consultation", "fee": "5000 RWF"}, ...]
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([id, name, address])
}